# Образец переменных окружения. РЕАЛЬНЫЕ значения сюда НЕ вписывай —
# они хранятся только в .env.local (он в .gitignore) и в настройках Vercel.

# === Supabase (Project Settings -> API Keys, формат eyJ...) ===
NEXT_PUBLIC_SUPABASE_URL=https://ВАШ-ПРОЕКТ.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ВАШ_ANON_КЛЮЧ_eyJ...
SUPABASE_SERVICE_ROLE_KEY=ВАШ_SERVICE_ROLE_КЛЮЧ_eyJ...

# === LLM ===
# console.groq.com -> API Keys
GROQ_API_KEY=gsk_...
# aistudio.google.com -> Get API key
GEMINI_API_KEY=...

# === Telegram ===
# @BotFather -> /newbot. Бот должен быть админом канала.
TELEGRAM_BOT_TOKEN=
# @channel_username или -100xxxxxxxxxx
TELEGRAM_CHANNEL_ID=
# Личный chat_id главреда для уведомлений об ошибках (узнать: @userinfobot)
TELEGRAM_ADMIN_CHAT_ID=

# === Сайт ===
# Секрет для входа в /admin (придумай длинную случайную строку)
ADMIN_KEY=придумайте-длинную-строку
# Публичный URL сайта (для ссылок в TG-постах)
SITE_URL=http://localhost:3000

# Если ключи не заполнены, проект работает в МОК-РЕЖИМЕ:
# сайт показывает демо-статьи, воркер пишет в консоль.
